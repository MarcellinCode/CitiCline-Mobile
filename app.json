{
  "expo": {
    "name": "CITICLINE",
    "slug": "citicline",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.recycla.citicline",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "CITICLINE a besoin de la caméra pour prendre en photo les preuves de travail et dépôts sauvages."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "CITICLINE nécessite votre position GPS pour l'itinéraire et les alertes environnement.",
          "locationAlwaysPermission": "Position vitale pour le suivi des agents en arrière-plan.",
          "locationWhenInUsePermission": "Position nécessaire pour géolocaliser les déchets signalés."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "CITICLINE doit accéder à la galerie pour charger les images de signalements."
        }
      ]
    ],
    "scheme": "citicline",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "117e2e35-8467-42bd-a0f5-fe0438793f5a"
      }
    },
    "owner": "citicline"
  }
}
